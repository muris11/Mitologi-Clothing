COMPANY_NAME="Mitologi Clothing"
SITE_NAME="Mitologi"
NEXT_PUBLIC_API_URL="http://__HOST__:8011/api"
# Optional internal API URL for server-side runtime (useful when Next.js runs in WSL and backend runs on Windows host)
# INTERNAL_API_URL="http://host.docker.internal:8011/api"
INTERNAL_API_URL="http://127.0.0.1:8011/api"
NEXT_PUBLIC_SITE_URL="http://__HOST__:3011"
NEXT_PUBLIC_SHIPPING_ORIGIN="Indramayu, Jawa Barat"

# Midtrans Payment Gateway (Sandbox)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-xxx"
NEXT_PUBLIC_MIDTRANS_SNAP_URL="https://app.sandbox.midtrans.com/snap/snap.js"

# On-demand Revalidation Secret (generate a random string for production)
REVALIDATION_SECRET="your-secret-here"

# AI Recommendation Service
NEXT_PUBLIC_AI_SERVICE_URL="http://__HOST__:8001"
