APP_NAME="Mitologi Clothing"
APP_ENV=local
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
VITE_DEV_SERVER_URL=http://localhost:5173

# Midtrans (Sandbox)
MIDTRANS_SERVER_KEY=SB-Mid-server-YOUR_KEY
MIDTRANS_CLIENT_KEY=SB-Mid-client-YOUR_KEY
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_MERCHANT_ID=YOUR_MERCHANT_ID

# AI Service (Standard port 8001)
AI_SERVICE_URL=http://localhost:8001/api

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:3011

FRONTEND_URL=http://localhost:3011
CORS_ALLOWED_ORIGINS=http://localhost:3011

# Groq API Keys (comma-separated for multiple keys)
# Get from: https://console.groq.com/
GROQ_API_KEYS=gsk_YOUR_FIRST_KEY,gsk_YOUR_SECOND_KEY

# Next.js Frontend Cache Revalidation
NEXTJS_URL=http://localhost:3011
NEXTJS_REVALIDATION_SECRET=your-secret-key
RECOMMENDER_API_KEY=your-recommender-key
